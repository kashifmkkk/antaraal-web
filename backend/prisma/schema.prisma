generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VENDOR
  BUYER
}

enum OrderStatus {
  Pending
  Processing
  Shipped
  Delivered
  Cancelled
}

enum ReviewStatus {
  Pending
  Approved
  Rejected
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  productCount Int      @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id              Int              @id @default(autoincrement())
  name            String
  category        String?
  categoryId      Int?
  categoryModel   Category?        @relation(fields: [categoryId], references: [id])
  image           String
  photos          String[]         @default([])
  description     String?
  referenceCode   String?          @unique
  vendor          String?
  price           String?
  availability    String?          @default("On Request")
  warranty        String?
  warrantyStatus  String           @default("Active")
  rating          Float?
  reviewCount     Int              @default(0)
  status          String?          @default("available")
  warrantyExpiry  DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  warrantyRecords WarrantyRecord[]
  complaints      Complaint[]
  cartItems       Cart[]
  notifications   Notification[]
  reviews         Review[]
}

model Vendor {
  id                 Int              @id @default(autoincrement())
  name               String           @unique
  location           String?
  rating             Float?
  specialty          String?
  image              String?
  verificationStatus String           @default("Pending")
  isActive           Boolean          @default(true)
  certifications     String[]         @default([])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  warrantyRecords    WarrantyRecord[]
  complaints         Complaint[]
  users              User[]
  rfqs               RFQ[]            @relation("AssignedVendorRFQs")
  quotes             Quote[]
  notifications      Notification[]
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  passwordHash  String
  role          Role           @default(BUYER)
  isActive      Boolean        @default(true)
  lastActiveAt  DateTime       @default(now())
  vendorId      Int?
  vendor        Vendor?        @relation(fields: [vendorId], references: [id])
  quotes        Quote[]
  rfqs          RFQ[]          @relation("BuyerRFQs")
  notifications Notification[]
}

model RFQ {
  id               Int      @id @default(autoincrement())
  name             String
  company          String?
  email            String
  phone            String?
  partNumber       String?
  message          String?
  fileUrl          String?
  status           String   @default("New")
  assignedVendorId Int?
  assignedVendor   Vendor?  @relation("AssignedVendorRFQs", fields: [assignedVendorId], references: [id])
  internalNotes    String?
  createdAt        DateTime @default(now())
  quotes           Quote[]
  buyerId          Int?
  buyer            User?    @relation("BuyerRFQs", fields: [buyerId], references: [id])
}

model Quote {
  id         Int       @id @default(autoincrement())
  rfq        RFQ       @relation(fields: [rfqId], references: [id])
  rfqId      Int
  user       User?     @relation(fields: [userId], references: [id])
  userId     Int?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id])
  vendorId   Int?
  amount     Float
  currency   String    @default("INR")
  status     String    @default("Draft")
  comments   String?
  issuedAt   DateTime  @default(now())
  validUntil DateTime?
  createdAt  DateTime  @default(now())
}

model Complaint {
  id          Int      @id @default(autoincrement())
  subject     String
  description String?
  status      String   @default("New")
  product     Product  @relation(fields: [productId], references: [id])
  productId   Int
  vendor      Vendor?  @relation(fields: [vendorId], references: [id])
  vendorId    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WarrantyRecord {
  id         Int      @id @default(autoincrement())
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  vendor     Vendor?  @relation(fields: [vendorId], references: [id])
  vendorId   Int?
  tailNumber String?
  expiryDate DateTime
  status     String   @default("Active")
  createdAt  DateTime @default(now())
}

model MroOrder {
  id               Int      @id @default(autoincrement())
  tailNumber       String
  provider         String
  serviceType      String
  status           String   @default("Scheduled")
  estimatedTatDays Int
  startDate        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AdminSetting {
  id                Int     @id @default(1)
  notificationEmail String  @default("ops@skyway.aero")
  rfqAutoAssign     Boolean @default(false)
  dailyDigest       Boolean @default(false)
  complianceNotes   String  @default("")
}

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  quantity  Int      @default(1)
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  orderNumber     String      @unique
  totalAmount     Float
  currency        String      @default("INR")
  status          String      @default("Pending")
  shippingAddress String?
  billingAddress  String?
  paymentMethod   String?
  paymentStatus   String      @default("Pending")
  trackingNumber  String?
  shippingCarrier String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  productId Int
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
}

model WarrantyClaim {
  id          Int      @id @default(autoincrement())
  userId      Int
  productId   Int
  recordId    Int?
  subject     String
  description String?
  status      String   @default("Pending")
  response    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  body      String?
  userId    Int?
  vendorId  Int?
  productId Int?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  vendor  Vendor?  @relation(fields: [vendorId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
}

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  userId    Int
  userName  String
  rating    Int
  comment   String?
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([status])
}
